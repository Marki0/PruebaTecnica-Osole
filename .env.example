APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Instalación: PHP 8.2+ (ver README y composer.json). Composer 2.x.

# Imagen de fondo del hero en la home (URL absoluta o ruta bajo public/). Por defecto: Nikitos/hero-fondo.png vía nikitos:link-assets
# HOME_HERO_BACKGROUND_URL=

# Catálogo PDF en public/ (nombre de archivo) y nombre al descargar
# CATALOG_PDF_PATH=catalogo-nikitos-2026.pdf
# CATALOG_DOWNLOAD_FILENAME=Nikitos-Catalogo-2026.pdf

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base por defecto: SQLite (no requiere MySQL). Creá el archivo: touch database/database.sqlite
DB_CONNECTION=sqlite
# Opcional: ruta absoluta al .sqlite. Si no definís DB_DATABASE, Laravel usa database/database.sqlite
# DB_DATABASE=/ruta/completa/database.sqlite

# Si preferís MySQL, comentá lo de arriba y descomentá:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=nikitos
# DB_USERNAME=root
# DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
